# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and MUST NEVER be committed.
# Keep only non-secret defaults and placeholders here.

# -- App --
APP_ENV=development
LOG_LEVEL=INFO

# -- Primary DB (raw + intermediate data) --
DB_PRIMARY_URL=postgresql+psycopg://user:password@localhost:5432/fx_primary

# -- Secondary DB (aggregated / analytics data) --
DB_SECONDARY_URL=postgresql+psycopg://user:password@localhost:5432/fx_secondary

# -- Data source (broker / price feed) -- not yet used
# DATA_API_KEY=
# DATA_API_SECRET=
