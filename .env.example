# ---------------------------------------------------------------------------
# fx-ai-trading environment template
# Copy this file to .env and fill in the values.
# .env is gitignored and MUST NEVER be committed (contains secrets).
# ---------------------------------------------------------------------------

# --- Database (required) ---------------------------------------------------
# PostgreSQL connection string used by Supervisor, services, and Dashboard.
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:yourpassword@localhost:5432/fx_ai_trading

# --- OANDA broker (required for ctl start) ---------------------------------
# Iteration 2 operates demo-only. Set OANDA_ACCOUNT_TYPE=demo and use a demo
# access token from your OANDA practice account (https://www.oanda.com/demo).
# Live trading is gated by the 4-defense (docs/phase6_hardening.md §6.18 +
# docs/operations.md §2.1 Step 9 runbook) and is NOT enabled in Iteration 2.
# Switching to live also requires updating .env to OANDA_ACCOUNT_TYPE=live and
# a live token, then starting with `ctl start --confirm-live-trading`.
OANDA_ACCESS_TOKEN=your_oanda_demo_access_token_here
OANDA_ACCOUNT_TYPE=demo

# --- Notifier: Slack (optional, fan-out path 2 of 3) -----------------------
# Incoming Webhook URL for Slack alerts. Leave empty to disable Slack delivery;
# the File path (logs/notifications.jsonl) still records every notification.
SLACK_WEBHOOK_URL=

# --- Notifier: Email / SMTP (optional, fan-out path 3 of 3) ----------------
# All SMTP_* values must be set for Email delivery to activate; otherwise
# Notifier silently skips the email fan-out path. SMTP_RECIPIENTS is a
# comma-separated list (e.g. "ops@example.com,oncall@example.com").
SMTP_HOST=
SMTP_PORT=
SMTP_SENDER=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_RECIPIENTS=
